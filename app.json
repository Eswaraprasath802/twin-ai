{
  "expo": {
    "name": "Twin AI",
    "slug": "twin-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#05060A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.twinai",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Twin AI uses your location to show local weather and climate alerts."
      }
    },
    "android": {
      "package": "com.yourcompany.twinai",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "web": {
      "bundler": "metro"
    }
  }
}
